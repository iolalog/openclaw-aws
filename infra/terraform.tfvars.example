# All secrets are stored in AWS SSM Parameter Store and fetched at boot — NOT Terraform variables.
# Store them once before deploying (see docs/setup.md step 3b):
#   /openclaw/anthropic-api-key   (sk-ant-...)
#   /openclaw/slack-bot-token     (xoxb-...)
#   /openclaw/slack-app-token     (xapp-...)
#   /openclaw/openrouter-api-key  (sk-or-...)
#   /openclaw/gemini-api-key      (AIza-...)
github_memory_repo = "git@github.com:YOUR_USERNAME/openclaw-memory.git"
github_infra_repo  = "git@github.com:YOUR_USERNAME/openclaw-aws.git"
aws_region         = "eu-north-1"
